*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:Inter,Arial,sans-serif;
}

body{
  background:#050507;
  color:#fff;
  overflow-x:hidden;
}

body::before{
  content:'';
  position:fixed;
  inset:0;
  background:
    radial-gradient(circle at top,#ff005522,transparent 35%),
    radial-gradient(circle at bottom right,#ff005511,transparent 30%);
  pointer-events:none;
}

.app{
  display:flex;
  min-height:100vh;
}

.sidebar{
  width:230px;
  background:#07070b;
  border-right:1px solid rgba(255,0,92,.12);
  padding:20px;
  display:flex;
  flex-direction:column;
  justify-content:space-between;
}

.brand h1{
  color:#ff005c;
  font-size:34px;
  line-height:1;
}

.brand span{
  color:#fff;
  font-size:12px;
  letter-spacing:3px;
}

.sidebar-nav{
  display:flex;
  flex-direction:column;
  gap:10px;
  margin-top:28px;
}

.sidebar-nav a{
  text-decoration:none;
  color:#d4d4d8;
  background:#0e0e13;
  padding:14px 16px;
  border-radius:12px;
  font-size:13px;
  transition:.25s;
  border:1px solid transparent;
}

.sidebar-nav a:hover,
.sidebar-nav a.active{
  border-color:#ff005c;
  background:#130811;
  color:#fff;
  box-shadow:0 0 24px rgba(255,0,92,.16);
}

.family-status{
  background:#0e0e13;
  border:1px solid rgba(255,0,92,.12);
  padding:16px;
  border-radius:16px;
}

.status-title{
  font-size:12px;
  margin-bottom:8px;
}

.status-online{
  color:#00ff88;
  font-size:12px;
}

.content{
  flex:1;
  padding:22px;
}

.topbar{
  background:#09090d;
  border:1px solid rgba(255,255,255,.04);
  padding:18px 22px;
  border-radius:18px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:18px;
}

.hero-banner{
  position:relative;
  height:360px;
  overflow:hidden;
  border-radius:26px;
  margin-bottom:18px;
  border:1px solid rgba(255,0,92,.15);
  background:
    linear-gradient(rgba(0,0,0,.5),rgba(0,0,0,.78)),
    url('https://images.unsplash.com/photo-1514565131-fce0801e5785?q=80&w=1800&auto=format&fit=crop');
  background-size:cover;
  background-position:center;
}

.hero-left{
  position:relative;
  z-index:2;
  max-width:620px;
  padding:40px;
}

.welcome{
  font-size:13px;
  letter-spacing:4px;
}

.hero-banner h1{
  font-size:72px;
  line-height:.95;
  margin:12px 0 18px;
  color:#ff005c;
}

.hero-banner h1 span{
  color:#fff;
}

.hero-banner p{
  color:#d6d6db;
  line-height:1.6;
}

.hero-buttons{
  display:flex;
  gap:12px;
  margin-top:24px;
}

.primary-btn,
.secondary-btn{
  border:none;
  cursor:pointer;
  padding:14px 22px;
  border-radius:12px;
  font-weight:700;
  color:#fff;
}

.primary-btn{
  background:#ff005c;
  box-shadow:0 0 24px rgba(255,0,92,.35);
}

.secondary-btn{
  background:#111117;
  border:1px solid rgba(255,255,255,.06);
}

.stats-row{
  display:grid;
  grid-template-columns:repeat(5,1fr);
  gap:14px;
  margin-bottom:18px;
}

.stat-box{
  background:#09090d;
  border-radius:16px;
  border:1px solid rgba(255,0,92,.12);
  padding:20px;
}

.stat-box h3{
  color:#ff005c;
  font-size:28px;
  margin-bottom:8px;
}

.stat-box span{
  color:#888894;
  font-size:12px;
}

.dashboard-layout{
  display:grid;
  grid-template-columns:1.2fr 1fr 1fr;
  gap:14px;
}

.panel{
  background:#09090d;
  border-radius:18px;
  border:1px solid rgba(255,0,92,.12);
  padding:22px;
}

.panel h2{
  color:#ff005c;
  font-size:15px;
  margin-bottom:16px;
}

.panel p{
  color:#b8b8c2;
  line-height:1.7;
}

.news-item,
.top-user{
  background:#121219;
  padding:12px;
  border-radius:12px;
  margin-bottom:10px;
  font-size:13px;
}

.small-btn{
  margin-top:20px;
}

table{
  width:100%;
  border-collapse:collapse;
}

th,td{
  padding:16px;
  border-bottom:1px solid rgba(255,255,255,.05);
}

@media(max-width:1100px){
  .stats-row{
    grid-template-columns:repeat(2,1fr);
  }

  .dashboard-layout{
    grid-template-columns:1fr;
  }
}

@media(max-width:850px){
  .sidebar{
    display:none;
  }

  .content{
    padding:12px;
  }

  .hero-banner h1{
    font-size:48px;
  }

  .topbar{
    flex-direction:column;
    align-items:flex-start;
    gap:12px;
  }
}


.team-page{
  display:flex;
  flex-direction:column;
  gap:18px;
}

.team-header{
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  gap:20px;
}

.team-header h1{
  color:#ff005c;
  font-size:42px;
  margin-bottom:8px;
}

.team-header p{
  color:#8e8e98;
}

.team-stats{
  display:flex;
  gap:12px;
}

.team-stat{
  min-width:140px;
  padding:18px;
  border-radius:16px;
  background:#09090d;
  border:1px solid rgba(255,0,92,.12);
}

.team-stat h3{
  color:#ff005c;
  font-size:32px;
  margin-bottom:8px;
}

.team-stat span{
  font-size:11px;
  color:#7c7c86;
}

.team-controls{
  display:flex;
  justify-content:space-between;
  gap:16px;
  align-items:center;
}

.tabs{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
}

.tabs button{
  background:#0d0d12;
  border:1px solid rgba(255,255,255,.05);
  color:#c9c9d2;
  padding:12px 18px;
  border-radius:12px;
  cursor:pointer;
  font-size:12px;
}

.tabs button.active{
  background:#ff005c;
  color:white;
  box-shadow:0 0 20px rgba(255,0,92,.25);
}

.search-row input{
  background:#0d0d12;
  border:1px solid rgba(255,255,255,.05);
  padding:14px 16px;
  border-radius:12px;
  color:white;
  width:260px;
}

.members-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
  gap:16px;
}

.member-panel{
  position:relative;
  overflow:hidden;
  min-height:300px;
  border-radius:18px;
  border:1px solid rgba(255,0,92,.14);
  background:
    linear-gradient(rgba(0,0,0,.2),rgba(0,0,0,.85)),
    url('https://images.unsplash.com/photo-1511367461989-f85a21fda167?q=80&w=1200&auto=format&fit=crop');
  background-size:cover;
  background-position:center;
}

.member-overlay{
  position:absolute;
  inset:0;
  background:
    linear-gradient(to top,rgba(0,0,0,.95),rgba(0,0,0,.1)),
    rgba(255,0,92,.1);
}

.member-content{
  position:absolute;
  left:18px;
  right:18px;
  bottom:18px;
  z-index:2;
}

.member-content h3{
  font-size:26px;
  margin-bottom:8px;
}

.member-role{
  display:inline-block;
  padding:6px 10px;
  border-radius:999px;
  background:#ff005c22;
  border:1px solid rgba(255,0,92,.3);
  color:#ff6f9f;
  font-size:11px;
  margin-bottom:12px;
}

.member-money{
  font-size:18px;
  color:#fff;
  margin-bottom:10px;
}

.online{
  color:#00ff88;
  font-size:13px;
}

.offline{
  color:#ff4b6e;
  font-size:13px;
}

@media(max-width:900px){
  .team-header{
    flex-direction:column;
  }

  .team-stats{
    width:100%;
    flex-wrap:wrap;
  }

  .team-controls{
    flex-direction:column;
    align-items:flex-start;
  }

  .search-row{
    width:100%;
  }

  .search-row input{
    width:100%;
  }
}



.contracts-page{
  display:flex;
  flex-direction:column;
  gap:18px;
}

.contracts-header h1{
  color:#ff005c;
  font-size:42px;
  margin-bottom:8px;
}

.contracts-header p{
  color:#8b8b95;
}

.contracts-layout{
  display:grid;
  grid-template-columns:340px 1fr;
  gap:18px;
}

.contract-form-panel,
.contracts-table-panel{
  background:#09090d;
  border:1px solid rgba(255,0,92,.12);
  border-radius:18px;
  padding:22px;
}

.contract-form-panel h2,
.contracts-table-panel h2{
  color:#ff005c;
  font-size:18px;
  margin-bottom:20px;
}

.contract-form-panel{
  display:flex;
  flex-direction:column;
}

.contract-form-panel input,
.contract-form-panel textarea{
  width:100%;
  background:#0f0f14;
  border:1px solid rgba(255,255,255,.05);
  border-radius:12px;
  padding:14px 16px;
  color:white;
  margin-bottom:14px;
}

.contract-form-panel textarea{
  min-height:120px;
  resize:none;
}

.participants-count{
  color:#8f8f99;
  font-size:12px;
  margin-bottom:16px;
}

.full-btn{
  width:100%;
}

.table-top{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:18px;
}

.contracts-table-panel table{
  width:100%;
  border-collapse:collapse;
}

.contracts-table-panel th{
  color:#7f7f89;
  font-size:12px;
  font-weight:600;
  padding:14px;
}

.contracts-table-panel td{
  padding:16px 14px;
  border-top:1px solid rgba(255,255,255,.05);
  color:#d3d3db;
  font-size:13px;
}

.delete-btn{
  cursor:pointer;
  color:#ff005c;
}

.contracts-stats{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:16px;
}

.contract-stat-card{
  background:#09090d;
  border:1px solid rgba(255,0,92,.12);
  border-radius:18px;
  padding:22px;
}

.contract-stat-card span{
  display:block;
  color:#8a8a94;
  font-size:12px;
  margin-bottom:10px;
}

.contract-stat-card h3{
  font-size:42px;
  color:#ff005c;
}

.contract-stat-card.green h3{
  color:#00ff9d;
}

.contract-stat-card.pink h3{
  color:#ff2e88;
}

@media(max-width:1200px){
  .contracts-layout{
    grid-template-columns:1fr;
  }

  .contracts-stats{
    grid-template-columns:repeat(2,1fr);
  }
}

@media(max-width:700px){
  .contracts-stats{
    grid-template-columns:1fr;
  }

  .table-top{
    flex-direction:column;
    align-items:flex-start;
    gap:12px;
  }

  .contracts-table-panel{
    overflow:auto;
  }
}


/* ===== CONTRACTS TABLE FIX ===== */

.contracts-table-panel{
  overflow-x:auto;
}

.contracts-table-panel table{
  width:100%;
  min-width:1100px;
  border-collapse:collapse;
  table-layout:fixed;
}

.contracts-table-panel thead tr{
  border-bottom:1px solid rgba(255,255,255,.05);
}

.contracts-table-panel th{
  font-size:11px;
  letter-spacing:.5px;
  color:#7f7f89;
  padding:12px 10px;
  text-align:left;
  white-space:nowrap;
}

.contracts-table-panel td{
  padding:14px 10px;
  font-size:12px;
  color:#d7d7df;
  border-bottom:1px solid rgba(255,255,255,.04);
  vertical-align:middle;
}

.contracts-table-panel th:nth-child(1),
.contracts-table-panel td:nth-child(1){
  width:50px;
}

.contracts-table-panel th:nth-child(2),
.contracts-table-panel td:nth-child(2){
  width:220px;
}

.contracts-table-panel th:nth-child(3),
.contracts-table-panel td:nth-child(3){
  width:140px;
}

.contracts-table-panel th:nth-child(4),
.contracts-table-panel td:nth-child(4){
  width:170px;
}

.contracts-table-panel th:nth-child(5),
.contracts-table-panel td:nth-child(5){
  width:320px;
}

.contracts-table-panel th:nth-child(6),
.contracts-table-panel td:nth-child(6){
  width:140px;
}

.contracts-table-panel th:nth-child(7),
.contracts-table-panel td:nth-child(7){
  width:80px;
  text-align:center;
}

.delete-btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  width:32px;
  height:32px;
  border-radius:10px;
  background:#111117;
  border:1px solid rgba(255,0,92,.14);
  transition:.2s;
}

.delete-btn:hover{
  background:#190b13;
  border-color:#ff005c;
  box-shadow:0 0 14px rgba(255,0,92,.22);
}

.contracts-layout{
  align-items:start;
}

.contracts-table-panel::-webkit-scrollbar{
  height:8px;
}

.contracts-table-panel::-webkit-scrollbar-thumb{
  background:#ff005c55;
  border-radius:999px;
}



/* ===== PARTICIPANTS FIX ===== */

.contracts-table-panel table{
  table-layout:auto;
}

.contracts-table-panel td:nth-child(5){
  max-width:320px;
  white-space:normal;
  word-break:break-word;
  line-height:1.5;
}
