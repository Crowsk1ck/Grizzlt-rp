{
  "version": 2,

  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],

  "routes": [
    {
      "src": "/discord-members",
      "dest": "backend/server.js"
    }
  ]
}
{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],

  "crons": [
    {
      "path": "/src/api/weekly-report",
      "schedule": "0 18 * * 0"
    }
  ]
}
