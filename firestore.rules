rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function validText(value, max) {
      return value is string && value.size() > 0 && value.size() <= max;
    }

    function validDiscordUser(document) {
      return request.resource.data.discordUser is map
        && request.resource.data.discordUser.id is string
        && request.resource.data.discordUser.id == document;
    }

    match /applications/{document} {
      allow create: if validText(request.resource.data.nickname, 64)
        && validText(request.resource.data.discord, 120)
        && validText(request.resource.data.age, 20)
        && validText(request.resource.data.online, 80)
        && validText(request.resource.data.message, 2000)
        && validDiscordUser(document)
        && request.resource.data.source == 'grizzly-family-site';
      allow read, update, delete: if false;
    }

    match /messages/{document} {
      allow create: if validText(request.resource.data.nickname, 64)
        && validText(request.resource.data.discord, 120)
        && validText(request.resource.data.age, 20)
        && validText(request.resource.data.online, 80)
        && validText(request.resource.data.message, 2000)
        && request.resource.data.source == 'grizzly-family-site';
      allow read, update, delete: if false;
    }

    match /discord_members/{document} {
      allow read: if true;
      allow write: if false;
    }

    match /stats/{document} {
      allow read: if document == 'discord_members';
      allow write: if false;
    }

    match /news/{document} {
      allow read: if true;
      allow write: if false;
    }

    match /events/{document} {
      allow read: if true;
      allow create: if validText(request.resource.data.title, 120)
        && request.resource.data.type in ['meeting', 'war', 'training', 'convoy', 'other']
        && request.resource.data.date is string
        && request.resource.data.date.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && request.resource.data.time is string
        && request.resource.data.time.matches('^\\d{2}:\\d{2}$')
        && validText(request.resource.data.location, 160)
        && validText(request.resource.data.description, 2000)
        && request.resource.data.rewardMoney is number
        && request.resource.data.rewardXp is number
        && request.resource.data.participants is list
        && request.resource.data.createdBy is map
        && request.resource.data.createdBy.id is string
        && request.resource.data.createdBy.username is string;
      allow update: if request.resource.data.type in ['meeting', 'war', 'training', 'convoy', 'other']
        && request.resource.data.date is string
        && request.resource.data.time is string
        && request.resource.data.participants is list;
      allow delete: if true;
    }

    match /calculator_entries/{document} {
      allow read, write: if false;
    }

    match /calculator_contracts/{document} {
      allow read, write: if false;
    }

    match /calculator_settings/{document} {
      allow read, write: if false;
    }

    match /calculator_reports/{document} {
      allow read, write: if false;
    }

    match /member_profiles/{document} {
      allow read, write: if false;
    }

    match /member_warnings/{document} {
      allow read, write: if false;
    }

    match /admin_logs/{document} {
      allow read, write: if false;
    }

    match /discord_news_notifications/{document} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
